# MongoDB connection string (required)
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Payload CMS secret for auth/encryption (required, runtime only)
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Admin user auto-seeded on first boot (optional)
ADMIN_EMAIL=admin@yoursalon.com
ADMIN_PASSWORD=your-admin-password

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (SMTP) — optional; email is disabled when SMTP_HOST is unset.
# For Gmail with 2-Step Verification, create an App Password and paste it
# here WITHOUT quotes. Docker Compose preserves spaces in unquoted values,
# so "xxxx xxxx xxxx xxxx" and "xxxxxxxxxxxxxxxx" both work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Lumière Salon

# Seed secret — required for POST /api/seed from external apps (optional; admin session also works)
SEED_SECRET=

# App public URL (also passed as build ARG for Next.js)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# S3 / MinIO storage (required)
S3_ENDPOINT=http://minio:9000          # MinIO URL (also passed as build ARG for image remotePatterns)
S3_BUCKET=salon-demo                   # S3 bucket name
S3_PREFIX=salon/local                  # Upload prefix per demo instance (required, validated on startup)
S3_ACCESS_KEY=minioadmin               # S3/MinIO access key
S3_SECRET_KEY=minioadmin               # S3/MinIO secret key
S3_REGION=us-east-1                    # Default: us-east-1
S3_FORCE_PATH_STYLE=true               # Always true for MinIO

# MinIO container credentials (docker-compose only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
