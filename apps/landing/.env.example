# ── Core ──────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3001
PAYLOAD_SECRET=                    # Required. openssl rand -hex 32
DATABASE_URL=                      # Required. MongoDB connection string

# ── S3 Storage (landing app media) ───────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=landing
S3_PREFIX=media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ── Resend (optional — Payload email adapter) ────────
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@payloadreserve.com
RESEND_FROM_NAME=Payload Reserve

# ── Coolify (required for demo provisioning) ─────────
COOLIFY_API_URL=                   # e.g. https://coolify.yourdomain.com
COOLIFY_API_KEY=                   # Coolify API token

# ── Demo Display ────────────────────────────────────
DEMO_TTL_HOURS=24                  # Shown on the demo request page

# ── Cloudflare Turnstile (client-side) ──────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=    # Site key from Cloudflare dashboard

# ── Sentry (optional) ──────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Cloudflare Access (optional — zero-trust API protection) ──
# When set, /api routes (except public ones) require a valid
# CF Access JWT. Leave empty to disable (dev/local mode).
# See docs/cloudflare-access.md for setup instructions.
CF_ACCESS_TEAM_DOMAIN=             # Your CF Zero Trust team name (e.g. "myteam")
CF_ACCESS_POLICY_AUD=              # Application Audience (AUD) tag from CF Access app config

# ── NOTE ─────────────────────────────────────────────
# The following are managed via the InfrastructureSettings
# global in the Payload admin panel (not env vars):
#   Coolify project/server/destination UUIDs
#   Docker image names & tags
#   MongoDB root credentials & host (for demo DBs)
#   Resend API key & from address (for demo credential emails)
#   S3 credentials (for demo media cleanup)
#   Stripe keys
#   Turnstile secret key
#   Demo config (domain, protocol, max active, cleanup secret)
