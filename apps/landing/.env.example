# ================================================================
# Landing App Environment Variables (for Coolify / Docker / .env)
# ================================================================
# These configure the LANDING APP ITSELF (payload-reserve.com).
#
# Demo provisioning config (Coolify API, Docker images, shared Mongo,
# demo S3, demo SMTP, Stripe, Turnstile secret, cleanup secret, etc.)
# is managed in Admin Panel > Settings > Infrastructure Settings.
# ================================================================

# --- Required ---
NEXT_PUBLIC_SERVER_URL=http://payloadreserve.com
PAYLOAD_SECRET=generate-a-random-64-char-hex
DATABASE_URL=mongodb://user:pass@host:27017/landing?directConnection=true&authSource=admin

# --- Landing app media storage (S3/MinIO) ---
# These are for the landing app's OWN media uploads (screenshots, logos, etc.)
# NOT for demo container storage — that is configured in Infrastructure Settings.
S3_ENDPOINT=http://minio.internal:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET=landing-media
S3_PREFIX=media

# --- Landing app email (Payload CMS adapter) ---
# Used for Payload admin emails (password resets, notifications).
# Demo credential emails use SMTP from Infrastructure Settings (can be different).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=payload-reserve

# --- Turnstile (client-side widget — must be NEXT_PUBLIC) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Optional: seed ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
SEED_SECRET=

# ================================================================
# REMOVED from env — now in Infrastructure Settings global:
# ================================================================
# COOLIFY_API_URL, COOLIFY_API_KEY, COOLIFY_PROJECT_UUID,
# COOLIFY_SERVER_UUID, COOLIFY_DESTINATION_UUID
# DOCKER_IMAGE_SALON_NAME/TAG, DOCKER_IMAGE_HOTEL_NAME/TAG, etc.
# MONGO_HOST, MONGO_ROOT_USERNAME, MONGO_ROOT_PASSWORD
# DEMO_BASE_DOMAIN, DEMO_PROTOCOL, DEMO_TTL_HOURS, MAX_ACTIVE_DEMOS
# CLEANUP_SECRET, TURNSTILE_SECRET_KEY
# (all S3/SMTP/Stripe settings for demos)
# ================================================================
