# Database
DATABASE_URL=mongodb://127.0.0.1/payloadreserve-events
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Admin auto-creation (optional)
ADMIN_EMAIL=admin@events-demo.com
ADMIN_PASSWORD=changeme123

# Server URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3004

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
