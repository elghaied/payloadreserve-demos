{
  "name": "hotel",
  "version": "1.0.0",
  "description": "Grand Hotel — payload-reserve demo: room quantity, multi-night stays, date-range booking",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3002",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev -p 3002",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/cli.ts"
  },
  "dependencies": {
    "@payload-reserve-demos/seed-utils": "workspace:*",
    "@payloadcms/db-mongodb": "3.79.0",
    "@payloadcms/email-nodemailer": "3.79.0",
    "@payloadcms/next": "3.79.0",
    "@payloadcms/plugin-sentry": "^3.79.0",
    "@payloadcms/plugin-stripe": "3.79.0",
    "@payloadcms/richtext-lexical": "3.79.0",
    "@payloadcms/storage-s3": "^3.79.0",
    "@payloadcms/ui": "3.79.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.43.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "geist": "^1.7.0",
    "graphql": "^16.8.1",
    "lucide-react": "^0.577.0",
    "next": "15.4.11",
    "next-intl": "^4.8.2",
    "payload": "3.79.0",
    "payload-reserve": "^1.3.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "sharp": "0.34.2",
    "stripe": "^17",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@payload-reserve-demos/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  }
}
