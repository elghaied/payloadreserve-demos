# MongoDB connection string (required)
DATABASE_URL=mongodb://127.0.0.1/payloadreserve-hotel

# Payload CMS secret for auth/encryption (required, runtime only)
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Admin user auto-seeded on first boot (optional)
ADMIN_EMAIL=admin@grandhotel.com
ADMIN_PASSWORD=your-admin-password

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (SMTP) — optional; email is disabled when SMTP_HOST is unset.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Grand Hotel

# Seed secret — required for POST /api/seed from external apps
SEED_SECRET=

# App public URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3002

# S3 / MinIO storage (required)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=hotel-demo
S3_PREFIX=hotel/local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
